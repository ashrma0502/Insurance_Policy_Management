# Python bytecode — generated from app.py and db.py at runtime
__pycache__/
*.py[cod]
*.pyo

# Virtual environment — all installed packages (Flask, mysql-connector, etc.)
venv/

# User-uploaded profile pictures — not source code, ignored but dirs kept
static/uploads/agents/*
static/uploads/policyholders/*
!static/uploads/agents/.gitkeep
!static/uploads/policyholders/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
